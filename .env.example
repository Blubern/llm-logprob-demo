# ── Provider toggle ───────────────────────────────────────
# Set to "true" for Azure OpenAI, "false" for OpenAI.
# Defaults to "true" if omitted.
USE_AZURE=true

# ── API key (required for both providers) ─────────────────
OPENAI_API_KEY=your-api-key-here

# ── Azure OpenAI only (ignored when USE_AZURE=false) ─────
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
API_VERSION=2025-04-01-preview

# ── Model ─────────────────────────────────────────────────
# Azure: use your deployment name (e.g. gpt-5.2)
# OpenAI: use a model ID (e.g. gpt-4o, gpt-4o-mini)
LOGPROB_MODEL=gpt-5.2
