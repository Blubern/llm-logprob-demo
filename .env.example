# ── Provider selection ────────────────────────────────────
# Choose one: "azure", "openai", or "github"
# If omitted, falls back to USE_AZURE for backward compat.
PROVIDER=azure

# ── API key ───────────────────────────────────────────────
# Required for Azure OpenAI and OpenAI providers.
# For GitHub Models, set GITHUB_TOKEN instead (or reuse this).
OPENAI_API_KEY=your-api-key-here

# ── GitHub Models only (ignored for other providers) ──────
# A GitHub Personal Access Token (PAT) with model access.
# If omitted, falls back to OPENAI_API_KEY.
# GITHUB_TOKEN=ghp_your-github-pat-here

# ── Azure OpenAI only (ignored for other providers) ──────
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
API_VERSION=2025-04-01-preview

# ── Model ─────────────────────────────────────────────────
# Azure:  use your deployment name (e.g. gpt-5.2)
# OpenAI: use a model ID (e.g. gpt-4o, gpt-4o-mini)
# GitHub: use a model ID (e.g. gpt-4o, gpt-4o-mini)
LOGPROB_MODEL=gpt-5.2
